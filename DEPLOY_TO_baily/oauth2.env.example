# Google OAuth client for Capper SSO (oauth2-proxy at the nginx edge).
# Copy to oauth2.env (gitignored) and fill in your real credentials:
#
#   cp DEPLOY_TO_baily/oauth2.env.example DEPLOY_TO_baily/oauth2.env
#   $EDITOR DEPLOY_TO_baily/oauth2.env
#
# Create the client in Google Cloud Console -> APIs & Services -> Credentials
# -> OAuth 2.0 Client ID (type: Web application), with authorized redirect URI:
#   https://cloud.cappervm.com/oauth2/callback
#
# Only users whose Google email is in one of ALLOWED_DOMAINS may sign in.

OAUTH2_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH2_CLIENT_SECRET=your-client-secret
ALLOWED_DOMAINS=inpenetrix.com,inipi.org
