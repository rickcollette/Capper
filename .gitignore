/bin/
/build/
/CapDB/
/DIST/
/dist/
/tmp/
*.cap

# Stray build binaries left at the repo root (use bin/ instead).
/capper
/capper-agent
/capinit
/docgen

# Generated documentation (source lives in docs/src/).
/docs/dist/
/docs/generated/

# Local runtime working dir (make capper-run): live store, logs, pids, binaries,
# plus copied-in examples/docs/schemas. Ignore everything except the tracked
# README and Go module files.
/capper-run/*
!/capper-run/README.md
!/capper-run/go.mod
!/capper-run/go.sum

# Go test / coverage / profiling output.
*.test
*.out
*.prof
coverage.html

# OS / editor cruft.
.DS_Store

# Generated by examples/alpine/bootstrap.sh.
/examples/alpine/downloads/
/examples/alpine/rootfs/

# Deploy secrets (Google OAuth client) — track the tooling, never the secret.
deploy/oauth2.env

# apk.static workdir (alpine image build)
/examples/alpine/apktools/

# AlmaLinux image build artifacts
/examples/alma/rootfs/
/examples/alma/downloads/
