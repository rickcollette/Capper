{
  "name": "alpine",
  "version": "3.23.0",
  "rootfs": "./rootfs",
  "entrypoint": ["/sbin/capinit", "--", "/bin/sh"],
  "args": ["-lc", "echo hello from alpine && cat /etc/alpine-release && exec sleep 3600"],
  "env": {
    "PATH": "/bin:/sbin:/usr/bin:/usr/sbin"
  },
  "workingDir": "/",
  "shell": "/bin/sh",
  "user": {
    "uid": 0,
    "gid": 0
  },
  "network": {
    "enabled": true
  },
  "resources": {
    "memoryBytes": 134217728,
    "cpuTimeSecs": 300,
    "maxProcesses": 128,
    "fileSizeBytes": 16777216
  }
}
