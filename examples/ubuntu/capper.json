{
  "name": "ubuntu",
  "version": "24.04",
  "rootfs": "./rootfs",
  "entrypoint": ["/sbin/capinit", "--", "/bin/bash"],
  "args": ["-lc", "echo hello from ubuntu && cat /etc/os-release | grep PRETTY_NAME && exec sleep 3600"],
  "env": {
    "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },
  "workingDir": "/",
  "shell": "/bin/bash",
  "user": {
    "uid": 0,
    "gid": 0
  },
  "network": {
    "enabled": true
  },
  "resources": {
    "memoryBytes": 268435456,
    "cpuTimeSecs": 300,
    "maxProcesses": 256,
    "fileSizeBytes": 67108864
  }
}
